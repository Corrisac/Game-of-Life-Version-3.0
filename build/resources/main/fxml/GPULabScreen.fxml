<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="game.of.life.on.gpu.ui.GPULabController"
      stylesheets="@../css/dark-theme.css"
      style="-fx-background-color: #0A0F19;">

    <!-- Sidebar -->
    <VBox styleClass="sidebar" prefWidth="260" spacing="10" alignment="TOP_CENTER">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

        <Label text="GPU COMPUTE LAB" styleClass="sidebar-title"/>
        <Separator style="-fx-border-color: transparent transparent rgba(0,255,224,0.2) transparent;"/>

        <!-- Iteration Dial (Canvas-based, managed programmatically) -->
        <StackPane fx:id="dialContainer" prefWidth="220" prefHeight="220"/>

        <!-- Iteration input -->
        <Label text="ITERATIONS" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 12px;"/>
        <TextField fx:id="iterInput" promptText="Enter iterations..."
                   styleClass="neon-input" alignment="CENTER" maxWidth="200"
                   onAction="#onIterationEnter"/>

        <Region prefHeight="8"/>

        <!-- Action buttons -->
        <Button fx:id="btnCompute" text="▶ COMPUTE" styleClass="neon-button, orange"
                maxWidth="200" onAction="#compute"/>
        <Button text="🗑 CLEAR" styleClass="neon-button, small, red"
                maxWidth="200" onAction="#clear"/>
        <Button text="⬡ GLIDER" styleClass="neon-button, small"
                maxWidth="200" onAction="#spawnGlider"/>
        <Button text="⚙ GUN" styleClass="neon-button, small"
                maxWidth="200" onAction="#spawnGun"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Button text="← MENU" styleClass="neon-button, small, red"
                maxWidth="200" onAction="#goMenu"/>
    </VBox>

    <!-- Main content area -->
    <VBox HBox.hgrow="ALWAYS">
        <!-- Top bar with pane labels -->
        <HBox styleClass="toolbar" spacing="12">
            <Label text="✏ INPUT GRID" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="GPU RESULT" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 14px;"/>
        </HBox>

        <!-- Split pane: input grid | result -->
        <HBox VBox.vgrow="ALWAYS">
            <!-- Left: Editable input grid -->
            <StackPane fx:id="inputGridPane" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #0A0F19;">
                <Canvas fx:id="inputGridCanvas"/>
            </StackPane>

            <!-- Divider line -->
            <Region prefWidth="2" style="-fx-background-color: rgba(0,255,224,0.12);"/>

            <!-- Right: Result area -->
            <StackPane fx:id="resultPane" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #0A0F19;">
                <!-- Placeholder (shown when no result) -->
                <VBox fx:id="placeholderBox" alignment="CENTER" spacing="8">
                    <Label text="GPU OUTPUT" style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 18px;"/>
                    <Label text="Run compute to see result" style="-fx-text-fill: rgba(255,255,255,0.12); -fx-font-size: 14px;"/>
                </VBox>
                <!-- Progress overlay (shown during compute) -->
                <VBox fx:id="progressBox" visible="false" alignment="CENTER" spacing="12">
                    <Label text="COMPUTING..." style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                    <ProgressBar fx:id="progressBar" prefWidth="300" prefHeight="20"/>
                    <Label fx:id="progressLabel" style="-fx-text-fill: #00FFE0; -fx-font-size: 16px;"/>
                </VBox>
                <!-- Result canvas (shown after compute) -->
                <Canvas fx:id="resultCanvas" visible="false"/>
                <!-- Result stats banner -->
                <HBox fx:id="resultBanner" visible="false" alignment="CENTER"
                      StackPane.alignment="TOP_CENTER"
                      style="-fx-background-color: rgba(0,0,0,0.6); -fx-padding: 8 16;">
                    <Label fx:id="resultLabel" style="-fx-text-fill: #00FFE0; -fx-font-size: 15px;"/>
                </HBox>
            </StackPane>
        </HBox>
    </VBox>
</HBox>
