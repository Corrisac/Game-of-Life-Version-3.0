<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="game.of.life.on.gpu.ui.DualLabController"
            stylesheets="@../css/dark-theme.css"
            style="-fx-background-color: #0A0F19;">

    <!-- Top toolbar -->
    <top>
        <HBox styleClass="toolbar" spacing="12" alignment="CENTER_LEFT">
            <Label text="DUAL LAB — LIFE VS ANTILIFE" styleClass="toolbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statsLabel" styleClass="stats-text"/>
            <Region prefWidth="16"/>
            <Label fx:id="statusLabel" styleClass="status-paused" text="⏸ PAUSED"/>
        </HBox>
    </top>

    <!-- Center: resizable grid canvas + HUD overlay -->
    <center>
        <StackPane fx:id="gridPane" style="-fx-background-color: #0A0F19;">
            <Canvas fx:id="gridCanvas"/>

            <!-- HUD overlay — top-left, initially hidden -->
            <VBox fx:id="hudOverlay" visible="false" maxWidth="260" maxHeight="220"
                  StackPane.alignment="TOP_LEFT" styleClass="glass-card"
                  style="-fx-padding: 12; -fx-spacing: 5;"
                  mouseTransparent="true">
                <Label fx:id="hudLifeLabel"
                       style="-fx-text-fill: #00FFE0; -fx-font-size: 13px; -fx-font-family: 'Consolas', monospace;"/>
                <Label fx:id="hudAntiLabel"
                       style="-fx-text-fill: #FF3EA5; -fx-font-size: 13px; -fx-font-family: 'Consolas', monospace;"/>
                <Label fx:id="hudGenLabel"
                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-family: 'Consolas', monospace;"/>
                <Label fx:id="hudTpsLabel"
                       style="-fx-text-fill: #FF9F43; -fx-font-size: 13px; -fx-font-family: 'Consolas', monospace;"/>
                <!-- Dual sparkline canvas: Life = cyan line, Anti = pink line -->
                <Canvas fx:id="sparklineCanvas" width="225" height="55"/>
            </VBox>
        </StackPane>
    </center>

    <!-- Bottom toolbar with all controls -->
    <bottom>
        <HBox styleClass="toolbar, bottom" spacing="6" alignment="CENTER">

            <!-- Playback -->
            <Button fx:id="btnPause" text="⏯ PLAY"
                    styleClass="neon-button, small, green" onAction="#togglePause"/>
            <Button text="⬜ STEP"
                    styleClass="neon-button, small" onAction="#stepOnce"/>
            <Button text="🗑 CLEAR"
                    styleClass="neon-button, small, red" onAction="#clearGrid"/>

            <!-- Separator -->
            <Region prefWidth="6"/>

            <!-- Brush species selector -->
            <Button fx:id="btnBrushLife"  text="● LIFE"
                    styleClass="neon-button, small, brush-active-life" onAction="#selectLifeBrush"/>
            <Button fx:id="btnBrushAnti"  text="◆ ANTI"
                    styleClass="neon-button, small, antilife" onAction="#selectAntiBrush"/>
            <Button fx:id="btnBrushErase" text="○ ERASE"
                    styleClass="neon-button, small" onAction="#selectEraseBrush"/>

            <!-- Brush size -->
            <Button fx:id="btnBrush" text="✏ BRUSH: 1"
                    styleClass="neon-button, small" onAction="#cycleBrush"/>

            <!-- Separator -->
            <Region prefWidth="6"/>

            <!-- Speed + Presets -->
            <Button fx:id="btnSpeed" text="⚡ 1×"
                    styleClass="neon-button, small, orange" onAction="#cycleSpeed"/>
            <Button fx:id="btnPreset" text="⬡ DUEL"
                    styleClass="neon-button, small, purple" onAction="#loadPreset"/>

            <!-- HUD toggle -->
            <Button text="HUD"
                    styleClass="neon-button, small" onAction="#toggleHud"/>

            <!-- Zoom controls -->
            <Region prefWidth="6"/>
            <Button text="＋" styleClass="neon-button, small" onAction="#zoomIn"/>
            <Button text="－" styleClass="neon-button, small" onAction="#zoomOut"/>
            <Button text="1:1" styleClass="neon-button, small" onAction="#resetZoom"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="← MENU"
                    styleClass="neon-button, small, red" onAction="#goMenu"/>
        </HBox>
    </bottom>
</BorderPane>
